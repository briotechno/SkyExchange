"undefined"==typeof MobileUpcomingHandler&&(MobileUpcomingHandler={});
(function(){MobileUpcomingHandler.queryTask=null;MobileUpcomingHandler.init=function(){MobileUpcomingHandler.queryTask=TaskExecuter.createTask(PageCommonConfig.queryUpcomingHorseRaceCycleTime,0,function(){MobileUpcomingHandler.queryUpcomingHorseRace(this)});MobileUpcomingHandler.queryTask.run();TaskExecuter.execute()};MobileUpcomingHandler.abortTask=function(){null!=MobileUpcomingHandler.queryTask&&MobileUpcomingHandler.queryTask.stop()};MobileUpcomingHandler.queryUpcomingHorseRace=function(d){MobileUpcomingHandler.ajax(d)};
