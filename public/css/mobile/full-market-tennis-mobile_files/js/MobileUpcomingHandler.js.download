(EventType.HORSE_RACING.unique()+"&eventId="+a.eventId+"&marketId="+a.marketId)+'",true)',b=JsCache.clone("#upcomingRaceTempLate");b.prop("id","upcoming_"+a.marketId);b.find("a").html('<span class="time">'+a.marketName+"</span>"+a.startTime+" "+a.raceName);b.find("a").attr("href",g);c[0].startTime==a.startTime&&3>e?($j("#upcomingWrap").before(b),e++):(b.find("a").html('<span class="time">'+a.startTime+"</span>"+a.raceName),$j("#upcoming").append(b));b.show()}}}catch(h){Trace.printStackTrace(h)}finally{d.check(),
