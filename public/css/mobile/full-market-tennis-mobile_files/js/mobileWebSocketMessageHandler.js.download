var MobileWebSocketMessageHandler=function(){return{messageHandler:a=>{if(null!==a&&null!==a.messageType){a=JSON.parse(a);var b=a.messageType;WebSocketMessageType.FullMarketOdds.unique()==b?MobileFullMarketHandler.updateFullMarketByWs(a):WebSocketMessageType.MultiMarketOdds.unique()==b?MobileMultiMarketsHandler.updateMultiMarketByWs(a):WebSocketMessageType.RemovedMultiMarketPks.unique()==b?MobileMultiMarketsHandler.removeMultiMarketPks(a):WebSocketMessageType.MiniGameNormalPromo.unique()==b?MobileMenuHandler.miniGamePromo(a):
WebSocketMessageType.MiniGameFullMarketPromo.unique()==b?MobileMultiMarketsHandler.miniGameFullMarketPromo(a):WebSocketMessageType.FancyBetFullMarketOdds.unique()!=b&&WebSocketMessageType.FancyBetMultiMarketOdds.unique()}}}}();Object.freeze(MobileWebSocketMessageHandler);
const MobileWebSocketMessageHandlerV2=function(){return{messageHandler:a=>{if(null!==a)if("1"!==a.status)Trace.error(a.message);else switch(a.router){case WebSocketMsgType.FancybetInfo.router:1===a.pageType?MobileFancyBetMarketHandler.updateFancyBetMarketByWs(a.data):2===a.pageType?MobileFancyBetMultiMarketsHandler.updateFancyBetMarketByWs(a.data):Trace.log("pageType does not exist");break;case WebSocketMsgType.Connect.router:case WebSocketMsgType.Heartbeat.router:break;case WebSocketMsgType.Error.router:Trace.error(a.message);
break;default:Trace.error(a.router+"does not exist")}}}}();Object.freeze(MobileWebSocketMessageHandlerV2);

